{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  },
  "include": [
    "index.ts",
    "openclaw-register.ts",
    "openclaw-plugin.ts",
    "openclaw-wrapper.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "test",
    "benchmark",
    "docs"
  ]
}