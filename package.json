{
  "name": "memory-likehuman-pro",
  "version": "2.1.6",
  "description": "Unified knowledge graph + vector memory system for AI agents — v2.0.0 Scope 六层 + LanceDB",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "like-human-brain-memory-configure": "./scripts/configure.js",
    "like-human-brain-memory-setup": "./scripts/setup.js",
    "brain-memory-doctor": "./scripts/doctor.js"
  },
  "scripts": {
    "dev": "tsx watch index.ts",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:performance": "vitest run test/performance",
    "test:e2e": "vitest run test/e2e",
    "test:ci": "vitest run --reporter=junit --reporter=verbose",
    "lint": "npx eslint src/ openclaw-wrapper.ts openclaw-register.ts index.ts",
    "check:versions": "node -e \"const pkg = require('./package.json'); const fs = require('fs'); let ok = true; const check = (file, expected) => { const content = fs.readFileSync(file, 'utf8'); const m = content.match(/version:\\s*'([^']+)'/g); if (m) { m.forEach(v => { const ver = v.match(/'([^']+)'/)[1]; if (ver !== expected) { console.error('\\n❌ ' + file + ': version \\'' + ver + '\\' does not match package.json version \\'' + expected + '\\''); ok = false; } }); } }; check('openclaw-register.ts', pkg.version); check('openclaw-wrapper.ts', pkg.version); check('src/engine/context.ts', pkg.version); if (!ok) process.exit(1); console.log('✅ All version references match package.json (' + pkg.version + ')');\"",
    "build": "tsc",
    "build:all": "npm run clean && npm run build",
    "docs": "typedoc",
    "clean": "npx rimraf dist coverage",
    "prebuild": "npm run clean",
    "postinstall": "echo 'brain-memory installation complete'",
    "configure": "node scripts/configure.js",
    "setup-openclaw": "node scripts/setup.js",
    "doctor": "node scripts/doctor.js",
    "release": "bash scripts/release.sh",
    "publish": "bash scripts/publish-npm.sh",
    "lint:src": "eslint src/**/*.ts",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "memory",
    "knowledge-graph",
    "vector-embedding",
    "context-management",
    "llm",
    "openclaw-plugin",
    "typescript",
    "knowledge-extraction",
    "working-memory"
  ],
  "author": "DylingCreation",
  "license": "MIT",
  "dependencies": {
    "@photostructure/sqlite": "1.2.1",
    "hono": "^4.12.23",
    "tsx": "^4.21.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lancedb/lancedb": "^0.27.2",
    "@types/node": "^20.19.41",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DylingCreation/brain-memory.git"
  },
  "bugs": {
    "url": "https://github.com/DylingCreation/brain-memory/issues"
  },
  "homepage": "https://github.com/DylingCreation/brain-memory#readme",
  "openclaw": {
    "extensions": [
      "./dist/openclaw-register.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "package.json",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
