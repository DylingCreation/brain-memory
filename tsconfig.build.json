{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmitOnError": false,
    "skipLibCheck": true
  },
  "include": [
    "src/engine/context.ts",
    "src/types.ts",
    "src/store/db.ts",
    "src/store/store.ts",
    "src/extractor/extract.ts",
    "src/recaller/recall.ts",
    "src/fusion/analyzer.ts",
    "src/reflection/extractor.ts",
    "src/working-memory/manager.ts",
    "src/format/assemble.ts",
    "src/graph/pagerank.ts",
    "src/graph/community.ts",
    "src/graph/maintenance.ts",
    "src/decay/engine.ts",
    "src/noise/filter.ts",
    "src/temporal/classifier.ts",
    "src/engine/llm.ts",
    "src/engine/embed.ts",
    "src/utils/json.ts",
    "src/utils/xml.ts",
    "src/utils/text.ts",
    "src/reasoning/engine.ts",
    "src/scope/isolation.ts",
    "src/plugin/handler.ts",
    "index.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "test/**/*",
    "src/retriever/**/*",
