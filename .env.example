# brain-memory LLM Integration Test Environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# DashScope API Key (required for LLM integration tests)
DASHSCOPE_API_KEY=your_actual_api_key_here

# BaseURL (optional, defaults to DashScope compatible mode)
DASHSCOPE_BASE_URL=your_dashscope_base_url_here

# LLM model (optional, defaults to qwen3.6-plus)
DASHSCOPE_MODEL=your_model_name_here
