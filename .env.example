# brain-memory — Test Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM (DashScope / OpenAI-compatible) ───
TEST_LLM_API_KEY=your_dashscope_api_key_here
TEST_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEST_LLM_MODEL=qwen3.6-plus

# ─── Embedding (Ollama) ───
TEST_EMBEDDING_BASE_URL=http://localhost:11434/api
TEST_EMBEDDING_MODEL=bge-m3

# ─── LLM Test Gate ───
# Set to 1 to enable LLM-dependent tests (reflection, reasoning, fusion)
BM_LLM_TEST=1
