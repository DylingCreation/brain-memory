{
  "id": "brain-memory",
  "name": "Brain Memory",
  "version": "1.8.0",
  "description": "Unified knowledge graph + vector memory system for AI agents",
  "author": "DylingCreation",
  "license": "MIT",
  "contracts": {
    "hooks": [
      "session_start",
      "session_end",
      "message_received",
      "message_sent",
      "message_sending"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable the brain-memory plugin"
      },
      "mode": {
        "type": "string",
        "enum": ["full", "lite", "small"],
        "default": "full",
        "description": "Run mode: full=complete LLM pipeline, lite=heuristic-only, small=compact prompts for local models"
      },
      "engine": {
        "type": "string",
        "enum": ["graph", "vector", "hybrid"],
        "default": "graph",
        "description": "Engine mode: graph=knowledge graph, vector=vector search, hybrid=both"
      },
      "storage": {
        "type": "string",
        "enum": ["sqlite", "lancedb"],
        "default": "sqlite",
        "description": "Storage backend"
      },
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/brain-memory.db",
        "description": "Path to the database file"
      },
      "injectMemories": {
        "type": "boolean",
        "default": true,
        "description": "Whether to inject memories into conversation context"
      },
      "extractMemories": {
        "type": "boolean",
        "default": true,
        "description": "Whether to extract memories from conversations"
      },
      "autoMaintain": {
        "type": "boolean",
        "default": true,
        "description": "Whether to run maintenance automatically"
      },
      "recallCacheSize": {
        "type": "number",
        "default": 100,
        "description": "LRU cache capacity for recall queries"
      },
      "recallCacheTtlMs": {
        "type": "number",
        "default": 300000,
        "description": "Cache TTL in milliseconds (default 5 minutes)"
      },
      "llm": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "LLM API key"
          },
          "baseURL": {
            "type": "string",
            "default": "https://api.openai.com/v1",
            "description": "LLM API base URL"
          },
          "model": {
            "type": "string",
            "default": "gpt-4o-mini",
            "description": "LLM model to use"
          },
          "maxTokens": {
            "type": "number",
            "default": 4096,
            "description": "Max output tokens (v1.8.0)"
          }
        }
      },
      "embedding": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "Embedding API key"
          },
          "baseURL": {
            "type": "string",
            "default": "https://api.openai.com/v1",
            "description": "Embedding API base URL"
          },
          "model": {
            "type": "string",
            "default": "text-embedding-3-small",
            "description": "Embedding model to use"
          }
        }
      },
      "reflection": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "turnReflection": {
            "type": "boolean",
            "default": false
          },
          "sessionReflection": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "noiseFilter": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "minContentLength": {
            "type": "number",
            "default": 10
          }
        }
      },
      "workingMemory": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "maxTasks": {
            "type": "number",
            "default": 3
          },
          "maxDecisions": {
            "type": "number",
            "default": 5
          },
          "maxConstraints": {
            "type": "number",
            "default": 5
          }
        }
      },
      "fusion": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "similarityThreshold": {
            "type": "number",
            "default": 0.75
          },
          "minNodes": {
            "type": "number",
            "default": 20
          },
          "minCommunities": {
            "type": "number",
            "default": 3
          }
        }
      },
      "reasoning": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "maxHops": {
            "type": "number",
            "default": 2
          },
          "maxConclusions": {
            "type": "number",
            "default": 3
          },
          "minRecallNodes": {
            "type": "number",
            "default": 3
          }
        }
      },
      "memoryInjection": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "strategy": {
            "type": "string",
            "enum": ["full", "summary", "adaptive", "off"],
            "default": "adaptive"
          },
          "tokenBudget": {
            "type": "number",
            "default": 6000
          },
          "maxNodes": {
            "type": "number",
            "default": 12
          },
          "includeEpisodic": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "memorySharing": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "mode": {
            "type": "string",
            "enum": ["isolated", "mixed", "shared"],
            "default": "mixed"
          },
          "sharedCategories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": ["profile", "preferences"]
          },
          "allowedAgents": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      },
      "decay": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "recencyHalfLifeDays": {
            "type": "number",
            "default": 30
          },
          "timeDecayHalfLifeDays": {
            "type": "number",
            "default": 60
          }
        }
      },
      "rerank": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "compactTurnCount": {
        "type": "number",
        "default": 6
      },
      "recallMaxNodes": {
        "type": "number",
        "default": 6
      },
      "recallMaxDepth": {
        "type": "number",
        "default": 2
      },
      "recallStrategy": {
        "type": "string",
        "enum": ["full", "summary", "adaptive", "off"],
        "default": "full"
      },
      "dedupThreshold": {
        "type": "number",
        "default": 0.9
      },
      "pagerankDamping": {
        "type": "number",
        "default": 0.85
      },
      "pagerankIterations": {
        "type": "number",
        "default": 20
      }
    },
    "required": ["enabled"]
  }
}
